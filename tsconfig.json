{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": { "@/*": ["./*"] }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts", "lib/notes.js", "components/PrintButton.jsx", "components/ThemeToggle.jsx", "components/VirtualNote.jsx", "components/BlogShell.jsx", "app/api/chunk/route.js", "app/api/chunk/pdf/route.js", "app/test/page.jsx"],
  "exclude": ["node_modules"]
}
